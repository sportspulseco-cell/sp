{
  "name": "sportspulse",
  "version": "0.0.0",
  "private": true,
  "description": "SportsPulse — global, multi-sport league management platform",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "db:generate": "pnpm --filter @sportspulse/db generate",
    "db:migrate": "pnpm --filter @sportspulse/db migrate",
    "db:seed": "pnpm --filter @sportspulse/db seed",
    "db:studio": "pnpm --filter @sportspulse/db studio",
    "api:dev": "pnpm --filter @sportspulse/superadmin-api start:dev",
    "web:dev": "pnpm --filter @sportspulse/superadmin-web dev",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:install": "playwright install --with-deps chromium"
  },
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "@types/node": "^22.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  },
  "engines": {
    "node": ">=20.10.0",
    "pnpm": ">=9.0.0"
  }
}
