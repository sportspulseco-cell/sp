NODE_ENV=development
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres — use the pooled URL at runtime
DATABASE_POOL_URL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# Supabase Auth
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email). Leave RESEND_API_KEY empty to run in
# log-only mode — the API still surfaces rendered messages to the
# admin UI as a copy/paste fallback. EMAIL_FROM_ADDRESS defaults to
# Resend's onboarding sandbox, which only delivers to verified
# addresses on the free tier; set this to a verified domain before
# inviting real users.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=notifications@sportspulse.us

# Public-facing URL for the superadmin web app — used in email bodies
# (sign-in links, parent consent links, etc).
SUPERADMIN_WEB_URL=http://localhost:3000
