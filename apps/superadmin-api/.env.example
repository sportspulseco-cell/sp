NODE_ENV=development
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# Postgres — use the pooled URL at runtime
DATABASE_POOL_URL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# Supabase Auth
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=
