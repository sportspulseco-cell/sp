NODE_ENV=development
API_PORT=4000
# Comma-separated list of origins allowed by enableCors(). MUST include
# every web surface that talks to this API — locally + on Vercel. The
# preflight is silently rejected (no Allow-Origin header) for origins
# not listed here, which manifests as "Failed to fetch" in the browser
# (BUG-018).
CORS_ORIGIN=https://sp-superadmin.vercel.app,https://sp-org-admin.vercel.app,https://sp-player-red.vercel.app,https://sp-team-admin.vercel.app,https://sp-landing-seven.vercel.app,http://localhost:3000,http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004

# Postgres — use the pooled URL at runtime
DATABASE_POOL_URL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true

# Supabase Auth
SUPABASE_URL=https://<project_ref>.supabase.co
SUPABASE_JWT_SECRET=
SUPABASE_JWT_AUDIENCE=authenticated
SUPABASE_SERVICE_ROLE_KEY=

# Resend (transactional email). Leave RESEND_API_KEY empty to run in
# log-only mode — the API still surfaces rendered messages to the
# admin UI as a copy/paste fallback. EMAIL_FROM_ADDRESS defaults to
# Resend's onboarding sandbox, which only delivers to verified
# addresses on the free tier; set this to a verified domain before
# inviting real users.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=notifications@sportspulse.us

# Public-facing URL for the superadmin web app — used in email bodies
# (sign-in links, etc).
SUPERADMIN_WEB_URL=http://localhost:3000

# Public-facing URL for player-web — used to build parent-consent
# portal URLs in emails sent to the minor registrant's parent.
PLAYER_WEB_URL=https://sp-player-red.vercel.app

# Shared secret for pg_cron-driven endpoints (notifications retry,
# materialised-view refresh). pg_cron + pg_net post with
# `X-Cron-Secret: ${CRON_SECRET}`. Generate a long random string per
# environment; never log or commit. Migration 0034 sets the matching
# value in Postgres via `ALTER DATABASE ... SET app.cron_secret`.
CRON_SECRET=

# Web Push (VAPID). Leave both unset to run the push channel in
# log-only mode — the queue + pg_cron retry path still exercises,
# which is useful for dev. Generate once per env:
#   npx web-push generate-vapid-keys
# The public key is what browsers register with via the Push API.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:notifications@sportspulse.us

# Set to "true" in environments where new users must verify their
# email before they can sign in. Default (unset / "false") auto-
# confirms on user creation — fine for local + staging mock flows.
# With this flag on, Supabase sends a confirmation link to every new
# user; each app's /auth/callback exchanges the code for a session.
SUPABASE_REQUIRE_EMAIL_CONFIRM=false
