{
  "name": "@sportspulse/db",
  "version": "0.0.1",
  "private": true,
  "description": "SportsPulse data access layer — Drizzle schema, migrations, and client",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./schema": {
      "types": "./dist/schema/index.d.ts",
      "default": "./dist/schema/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "default": "./dist/client.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsc -p tsconfig.build.json --watch",
    "typecheck": "tsc --noEmit",
    "generate": "drizzle-kit generate",
    "generate:custom": "drizzle-kit generate --custom",
    "migrate": "tsx src/migrate.ts",
    "push": "drizzle-kit push",
    "studio": "drizzle-kit studio",
    "introspect": "drizzle-kit introspect",
    "seed": "tsx src/seed/index.ts",
    "seed:payments-demo": "tsx src/seed/payments-demo.ts",
    "check": "drizzle-kit check",
    "drop": "drizzle-kit drop"
  },
  "dependencies": {
    "drizzle-orm": "^0.36.4",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "dotenv": "^16.4.5",
    "drizzle-kit": "^0.28.1",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
