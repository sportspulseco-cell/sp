# Direct connection (port 5432) — used by drizzle-kit and migrate.ts
DATABASE_URL=postgresql://postgres:<password>@db.<project_ref>.supabase.co:5432/postgres?sslmode=require

# Pooled connection (port 6543, transaction mode) — used by app runtime
DATABASE_POOL_URL=postgresql://postgres.<project_ref>:<password>@aws-<region>.pooler.supabase.com:6543/postgres?sslmode=require&pgbouncer=true
