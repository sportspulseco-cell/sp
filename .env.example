# =====================================================================
# SportsPulse — Super Admin App (.env.example)
# Copy to .env and fill in values from Supabase Dashboard.
# =====================================================================

# ---------- App ----------
NODE_ENV=development
APP_NAME=sportspulse-superadmin
APP_PORT=3000
API_PORT=4000
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# ---------- Supabase (Auth + Postgres + GraphQL) ----------
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
SUPABASE_PROJECT_REF=

SUPABASE_AUTH_EMAIL_CONFIRM=true
SUPABASE_AUTH_REDIRECT_URL=http://localhost:3000/auth/callback

# ---------- Next.js (public) ----------
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_GRAPHQL_URL=

# ---------- Postgres ----------
DB_HOST=
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASSWORD=
DB_SCHEMA=public
DB_SSL=true

DATABASE_URL=
DATABASE_POOL_URL=

# ---------- pg_graphql ----------
PG_GRAPHQL_ENABLED=true
PG_GRAPHQL_ENDPOINT=

# ---------- NestJS ----------
NEST_CORS_ORIGIN=http://localhost:3000
NEST_LOG_LEVEL=debug

# ---------- JWT / Sessions ----------
JWT_SECRET=
JWT_AUDIENCE=authenticated
JWT_ISSUER=
SESSION_COOKIE_NAME=sp_session
SESSION_COOKIE_SECURE=false

# ---------- Drizzle ----------
DRIZZLE_OUT=./drizzle
DRIZZLE_SCHEMA=./src/db/schema.ts
DRIZZLE_DIALECT=postgresql

# ---------- Multi-tenancy ----------
RLS_TENANT_VAR=app.tenant_id
DEFAULT_LOCALE=en-US
DEFAULT_TIMEZONE=UTC
DEFAULT_CURRENCY=USD

# ---------- Observability ----------
LOG_LEVEL=debug
SENTRY_DSN=
OTEL_EXPORTER_OTLP_ENDPOINT=

# ---------- Feature Flags ----------
FEATURE_IMPERSONATION=true
FEATURE_BULK_IMPORT=true
FEATURE_DATA_MIGRATION=true
